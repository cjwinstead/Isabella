using ArgParse
using YAML

function parse_commandline()
    s = ArgParseSettings()
    @add_arg_table s begin
        "--commands", "-c"
        arg_type = Union{String,Nothing}
        help = "Specify YAML file with command definitions"
        default = nothing
        "--top", "-t"
        help = "Specify YAML file with top module definitions"
        arg_type = Union{String,Nothing}
        default = nothing
        "--test", "-b"
        help = "Generate a testbench file"
        action = :store_true
        "--project", "-p"
        help = "Generate project sources for controller"
        "--instantate", "-i"
        arg_type = String
        help="Generate instantiation template for specified module"
    end

    parse_args(s)

end

