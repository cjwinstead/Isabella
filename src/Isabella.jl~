function printCommandCodeParameters(data)
    s = string("")
    for x in data["commands"]
        s = string(s,"localparam ", x["name"], " = 8'h", x["hex"],";\n")
    end
    return s
end

function parseDownto(s)
    n=1
    if (s != nothing)
        r=r"\[([[:digit:]]+):0\]"
        m=match(r,s,1)
        n=1+parse(Int64,m.captures[1])
    end
    return n
end



function parseDeclaration(s)
    r=r"(input|output)[[:space:]]+(reg)?[[:space:]]*(\[[^[:space:]]+\])?[[:space:]]*([^[:space:],\[\]]+)(\[[^,]+\])?,?"
    m=match(r,s,1)
    if (m != nothing)
        portdirection=m.captures[1]
        portbits=m.captures[3]
        portname=m.captures[4]
        portdepth=m.captures[5]
        
        width=parseDownto(portbits)
        depth=parseDownto(portdepth)
        
        d=Dict{String,Union{Nothing,String}}("direction"=>portdirection,"name"=>portname,"width"=>string(width),"depth"=>string(depth))
        return d
    else
        return nothing
    end
end


function analyzePorts(data)
    inputString=data["inputs"]
    inports=split(inputString,"\n")
    data["inputPorts"]=Vector{Dict{String,Union{Nothing,String}}}()
    for x in inports
        d=parseDeclaration(x)
        if (d != nothing)
            push!(data["inputPorts"],d)
        end
    end

    outputString=data["outputs"]
    outports=split(outputString,"\n")
    data["outputPorts"]=Vector{Dict{String,Union{Nothing,String}}}()
    for x in outports
        d=parseDeclaration(x)
        if (d != nothing)
            push!(data["outputPorts"],d)
        end
    end
end



function portConnections(data)
    s=string("")
    for x in data["inputPorts"]
        s=string(s,"     .",x.name,"(",x.name,"),\n")
    end
    for x in data["outputPorts"]
        s=string(s,"     .",x.name,"(",x.name,"),\n")
    end
    return s
end


function portSignals(data)
    s=string("")
    for x in data["inputPorts"]
        s=string(s,"   reg ")
        if (x.width>1)
            s=string(s,"[",x.width-1,":0] ",x.name,";\n")
        end
    end
    for x in data["outputPorts"]
        s=string(s,"   wire ")
        if (x.width>1)
            s=string(s,"[",x.width-1,":0] ",x.name,";\n")
        end
    end
    return s
end


