function generateControllerProject(data)
    generateCommandCodes(data)
    tbl=printCommandCodeTable(data)
    docname=string("doc/",data["module"],"_commands.md")
    open(docname,"w") do file
        write(file,tbl)
    end

    d=commandCodeDict(data)
    s=translateProgram(data,d)
    programfile=string("programs/",data["module"],"_program.mem")
    open(programfile,"w") do file
        write(file,s)
    end

    srcname=string("src/",data["module"],".sv")
    src=generateVerilog(data)
    open(srcname,"w") do file
        write(file,src)
    end

    params=printCommandCodeParameters(data)
    codefile=string("inc/",data["module"],"_command_codes.sv")
    open(codefile,"w") do file
        write(file,params)
    end

    cmd=generateCommandSource(data)
    cmdfile=string("inc/",data["module"],"_commands.sv")
    open(cmdfile,"w") do file
        write(file,cmd)
    end

    flowsrc=flowCommandSource()
    open("inc/flow_commands.sv","w") do file
        write(file,flowsrc)
    end


    flowcodes=flowCommandCodes()
    open("inc/flow_command_codes.sv","w") do file
        write(file,flowcodes)
    end
end



    

